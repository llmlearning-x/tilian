# TILIAN 生产环境变量模板
# 复制到 /data/tilian/backend/.env 并根据实际情况修改
#
# 使用场景：
# - 服务器：火山引擎 ECS，公网 IP 115.190.7.207，无域名
# - 数据库：阿里云 RDS MySQL 8.0

# ============================================================
# 数据库配置（阿里云 RDS MySQL 8.0）
# ============================================================
DATABASE_URL=mysql+pymysql://用户名:密码@rm-bp12t8q5bo58ct10d4o.mysql.rds.aliyuncs.com:3306/数据库名

# ============================================================
# JWT 认证配置
# 必须替换为随机生成的长字符串
# ============================================================
SECRET_KEY=replace-this-with-a-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ============================================================
# Redis 配置（可选）
# 当前代码未强依赖 Redis，可不配置
# ============================================================
REDIS_URL=redis://127.0.0.1:6379/0

# ============================================================
# AI 模型配置（必须）
# 未配置时文档上传可用，但题目生成功能会失败
# ============================================================
LLM_PROVIDER=moonshot
LLM_API_URL=https://api.moonshot.cn/v1/chat/completions
LLM_API_KEY=your-moonshot-api-key
LLM_MODEL=moonshot-v1-8k
AGENT_LLM_MODEL=moonshot-v1-32k

# ============================================================
# 文件上传配置
# ============================================================
UPLOAD_DIR=/data/tilian/uploads
MAX_UPLOAD_BYTES=10485760

# ============================================================
# 应用配置
# ============================================================
DEBUG=False
API_V1_PREFIX=/api

# ============================================================
# CORS 配置
# 仅 IP 访问，必须包含服务器公网 IP
# ============================================================
CORS_ORIGINS=["http://115.190.7.207"]
